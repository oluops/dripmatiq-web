---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  jsonLd?: string;
  noindex?: boolean;
  articleMeta?: {
    publishedTime?: string;
    modifiedTime?: string;
    author?: string;
    section?: string;
    tags?: string[];
    readingTimeMin?: number;
  };
}

const {
  title,
  description = 'Dripmatiq scans your wardrobe, learns your taste, and builds daily outfits you\'ll actually wear.',
  ogImage,
  ogType = 'website',
  canonicalUrl,
  jsonLd,
  noindex = false,
  articleMeta,
} = Astro.props;

const siteUrl = 'https://dripmatiq.app';
const resolvedCanonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const resolvedOgImage = ogImage || `${siteUrl}/assets/icon.png`;

const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Dripmatiq',
  url: siteUrl,
  logo: `${siteUrl}/assets/icon.png`,
  sameAs: [
    'https://www.instagram.com/dripmatiq',
    'https://www.pinterest.com/dripmatiq',
    'https://twitter.com/dripmatiq',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Dripmatiq',
  url: siteUrl,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteUrl}/blog?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

const appSchema = {
  '@context': 'https://schema.org',
  '@type': 'MobileApplication',
  name: 'Dripmatiq',
  operatingSystem: 'iOS',
  applicationCategory: 'LifestyleApplication',
  description: 'Closet scanner that builds daily outfits from clothes you already own.',
  url: 'https://apps.apple.com/app/dripmatiq/id6760679168',
  installUrl: 'https://apps.apple.com/app/dripmatiq/id6760679168',
  offers: [
    { '@type': 'Offer', price: '0', priceCurrency: 'USD', name: 'Free' },
    { '@type': 'Offer', price: '6.99', priceCurrency: 'USD', name: 'Pro' },
    { '@type': 'Offer', price: '15.99', priceCurrency: 'USD', name: 'Elite' },
  ],
  publisher: { '@type': 'Organization', name: 'Dripmatiq', url: siteUrl },
};

const gscToken = import.meta.env.PUBLIC_GSC_VERIFICATION;
const bingToken = import.meta.env.PUBLIC_BING_VERIFICATION;
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const cfBeacon = import.meta.env.PUBLIC_CF_BEACON_TOKEN;
// Reddit Ads pixel. Defaults to the Dripmatiq pixel; set PUBLIC_REDDIT_PIXEL_ID='' to disable.
const redditPixelId = import.meta.env.PUBLIC_REDDIT_PIXEL_ID ?? 'a2_iy4gxvmjbu53';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-NWCMM2C02J"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-NWCMM2C02J');
    </script>

    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:site_name" content="Dripmatiq" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Dripmatiq Blog" href="/rss.xml" />

    <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />
    <meta name="theme-color" content="#0f0f0f" />

    <!-- Search engine verification -->
    {gscToken && <meta name="google-site-verification" content={gscToken} />}
    {bingToken && <meta name="msvalidate.01" content={bingToken} />}

    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>

    <!-- Site-wide structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    {isHome && <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />}
    {isHome && <script type="application/ld+json" set:html={JSON.stringify(appSchema)} />}

    <!-- Performance hints -->
    <link rel="preconnect" href="https://apps.apple.com" crossorigin />
    <link rel="dns-prefetch" href="https://apps.apple.com" />
    <link rel="dns-prefetch" href="https://plausible.io" />
    <link rel="dns-prefetch" href="https://static.cloudflareinsights.com" />

    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}

    {articleMeta?.publishedTime && <meta property="article:published_time" content={articleMeta.publishedTime} />}
    {articleMeta?.modifiedTime && <meta property="article:modified_time" content={articleMeta.modifiedTime} />}
    {articleMeta?.author && <meta property="article:author" content={articleMeta.author} />}
    {articleMeta?.section && <meta property="article:section" content={articleMeta.section} />}
    {articleMeta?.tags?.map((t) => <meta property="article:tag" content={t} />)}
    {articleMeta?.readingTimeMin && <meta name="twitter:label1" content="Reading time" />}
    {articleMeta?.readingTimeMin && <meta name="twitter:data1" content={`${articleMeta.readingTimeMin} min read`} />}

    <!-- Privacy-respecting analytics -->
    {plausibleDomain && (
      <script defer data-domain={plausibleDomain} src="https://plausible.io/js/script.outbound-links.js"></script>
    )}
    {cfBeacon && (
      <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={`{"token": "${cfBeacon}"}`}></script>
    )}
    {redditPixelId && (
      <!-- Reddit Ads pixel: PageVisit on load, Lead on any app-store click -->
      <script is:inline define:vars={{ redditPixelId }}>
        !(function (w, d) {
          if (!w.rdt) {
            var p = (w.rdt = function () {
              p.sendEvent ? p.sendEvent.apply(p, arguments) : p.callQueue.push(arguments);
            });
            p.callQueue = [];
            var t = d.createElement("script");
            (t.src = "https://www.redditstatic.com/ads/pixel.js"), (t.async = !0);
            var s = d.getElementsByTagName("script")[0];
            s.parentNode.insertBefore(t, s);
          }
        })(window, document);
        rdt("init", redditPixelId);
        rdt("track", "PageVisit");
        // Treat a click through to the App Store / Play Store as a Lead (install intent).
        document.addEventListener(
          "click",
          function (e) {
            var a = e.target && e.target.closest && e.target.closest("a[href]");
            if (!a) return;
            var href = a.getAttribute("href") || "";
            if (href.indexOf("apps.apple.com") !== -1 || href.indexOf("play.google.com") !== -1) {
              try {
                rdt("track", "Lead");
              } catch (err) {}
            }
          },
          true
        );
      </script>
    )}
  </head>
  <body class="bg-surface-primary text-content-primary antialiased">
    <slot />
  </body>
</html>
