---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonicalUrl?: string;
  jsonLd?: string;
}

const {
  title,
  description = 'Dripmatiq scans your wardrobe, learns your taste, and builds daily outfits you\'ll actually wear.',
  ogImage,
  ogType = 'website',
  canonicalUrl,
  jsonLd,
} = Astro.props;

const siteUrl = 'https://dripmatiq.app';
const resolvedCanonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const resolvedOgImage = ogImage || `${siteUrl}/assets/icon.png`;

const isHome = Astro.url.pathname === '/' || Astro.url.pathname === '';

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Dripmatiq',
  url: siteUrl,
  logo: `${siteUrl}/assets/icon.png`,
  sameAs: [
    'https://www.instagram.com/dripmatiq',
    'https://www.pinterest.com/dripmatiq',
    'https://twitter.com/dripmatiq',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Dripmatiq',
  url: siteUrl,
  potentialAction: {
    '@type': 'SearchAction',
    target: `${siteUrl}/blog?q={search_term_string}`,
    'query-input': 'required name=search_term_string',
  },
};

const gscToken = import.meta.env.PUBLIC_GSC_VERIFICATION;
const bingToken = import.meta.env.PUBLIC_BING_VERIFICATION;
const plausibleDomain = import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN;
const cfBeacon = import.meta.env.PUBLIC_CF_BEACON_TOKEN;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={resolvedCanonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:site_name" content="Dripmatiq" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={resolvedOgImage} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="Dripmatiq Blog" href="/rss.xml" />

    <!-- Search engine verification -->
    {gscToken && <meta name="google-site-verification" content={gscToken} />}
    {bingToken && <meta name="msvalidate.01" content={bingToken} />}

    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title}</title>

    <!-- Site-wide structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    {isHome && <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />}

    {jsonLd && <script type="application/ld+json" set:html={jsonLd} />}

    <!-- Privacy-respecting analytics -->
    {plausibleDomain && (
      <script defer data-domain={plausibleDomain} src="https://plausible.io/js/script.outbound-links.js"></script>
    )}
    {cfBeacon && (
      <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon={`{"token": "${cfBeacon}"}`}></script>
    )}
  </head>
  <body class="bg-surface-primary text-content-primary antialiased">
    <slot />
  </body>
</html>
