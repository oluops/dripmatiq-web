---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
};

const { post } = Astro.props;
const { Content } = await post.render();

const siteUrl = 'https://dripmatiq.app';
const postUrl = `${siteUrl}/blog/${post.slug}/`;
const heroSrc = post.data.heroImage || `/blog/${post.slug}/hero.svg`;
const heroJpg = heroSrc.replace(/\.svg$/, '.jpg');
const heroFull = new URL(heroJpg, siteUrl).href;

// Reading time + word count
const words = post.body?.split(/\s+/).filter(Boolean).length || 0;
const readingTime = Math.max(1, Math.ceil(words / 250));

// Related posts by tag overlap
const allPosts = await getCollection('blog');
const related = allPosts
  .filter((p) => p.slug !== post.slug)
  .map((p) => ({
    ...p,
    overlap: p.data.tags.filter((t: string) => post.data.tags.includes(t)).length,
  }))
  .filter((p) => p.overlap > 0)
  .sort((a, b) => b.overlap - a.overlap)
  .slice(0, 3);

const pubDateISO = post.data.pubDate.toISOString();
const pubDateFormatted = post.data.pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Combined JSON-LD graph (BlogPosting + Breadcrumb + optional FAQ/HowTo)
const author = post.data.author || 'Olu';
const graph: any[] = [
  {
    '@type': 'BlogPosting',
    '@id': `${postUrl}#article`,
    headline: post.data.title,
    description: post.data.description,
    image: heroFull,
    datePublished: pubDateISO,
    dateModified: post.data.updatedDate?.toISOString() || pubDateISO,
    wordCount: words,
    keywords: post.data.tags.join(', '),
    inLanguage: 'en-US',
    url: postUrl,
    author: {
      '@type': 'Person',
      name: author,
      url: `${siteUrl}/about/`,
    },
    publisher: {
      '@type': 'Organization',
      name: 'Dripmatiq',
      url: siteUrl,
      logo: { '@type': 'ImageObject', url: `${siteUrl}/assets/icon.png` },
    },
    mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
    articleSection: post.data.tags[0] || 'Style',
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}/` },
      { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog/` },
      { '@type': 'ListItem', position: 3, name: post.data.title, item: postUrl },
    ],
  },
];

if (post.data.faq && post.data.faq.length > 0) {
  graph.push({
    '@type': 'FAQPage',
    mainEntity: post.data.faq.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  });
}

if (post.data.howto) {
  graph.push({
    '@type': 'HowTo',
    name: post.data.howto.name,
    step: post.data.howto.steps.map((s, i) => {
      const text = typeof s === 'string' ? s : s.text;
      const name = typeof s === 'string' ? `Step ${i + 1}` : s.name;
      return { '@type': 'HowToStep', position: i + 1, name, text };
    }),
  });
}

const blogPostingLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': graph,
});

const appStoreUrl = `https://apps.apple.com/app/dripmatiq/id6743753909?utm_source=web&utm_medium=cta&utm_campaign=blog&utm_content=${post.slug}`;
const twitterShareUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(postUrl + '?utm_source=twitter&utm_medium=share')}`;
const pinterestShareUrl = `https://pinterest.com/pin/create/button/?url=${encodeURIComponent(postUrl + '?utm_source=pinterest&utm_medium=share')}&description=${encodeURIComponent(post.data.title)}&media=${encodeURIComponent(heroFull)}`;
---

<Base
  title={`${post.data.title} — Dripmatiq`}
  description={post.data.description}
  ogImage={heroFull}
  ogType="article"
  canonicalUrl={postUrl}
  jsonLd={blogPostingLd}
  articleMeta={{
    publishedTime: post.data.pubDate.toISOString(),
    modifiedTime: (post.data.updatedDate || post.data.pubDate).toISOString(),
    author: post.data.author || 'Olu',
    section: post.data.tags?.[0],
    tags: post.data.tags,
    readingTimeMin: readingTime,
  }}
>
  <Nav />
  <main class="pt-24 pb-16 px-4 sm:px-6">
    <article class="max-w-3xl mx-auto">
      <Breadcrumbs
        crumbs={[
          { label: 'Home', href: '/' },
          { label: 'Blog', href: '/blog/' },
          { label: post.data.title, href: postUrl },
        ]}
      />
      <!-- Top CTA -->
      <div class="mb-8 p-4 rounded-card bg-surface-elevated border border-border text-center">
        <p class="text-sm text-content-secondary mb-2">Style your closet with AI</p>
        <a
          href={appStoreUrl}
          class="inline-flex items-center gap-2 bg-gold hover:bg-gold-hover text-surface-primary font-bold text-sm px-5 py-2.5 rounded-btn tracking-button transition-colors duration-200"
        >
          Try Dripmatiq Free
        </a>
      </div>

      <!-- Hero image -->
      <div class="overflow-hidden rounded-card mb-8">
        <picture>
          <source srcset={heroSrc} type="image/svg+xml" />
          <img
            src={heroJpg}
            alt={post.data.heroAlt || post.data.title}
            width="1200"
            height="630"
            fetchpriority="high"
            decoding="async"
            class="w-full aspect-[1200/630] object-cover"
          />
        </picture>
      </div>

      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-4 text-sm text-content-muted mb-6">
        <time datetime={pubDateISO}>{pubDateFormatted}</time>
        <span>·</span>
        <span>{readingTime} min read</span>
      </div>

      <!-- Tags -->
      <div class="flex flex-wrap gap-2 mb-8">
        {post.data.tags.map((tag: string) => (
          <span class="text-xs uppercase tracking-wide text-gold bg-surface-elevated px-2 py-0.5 rounded-sm">
            {tag}
          </span>
        ))}
      </div>

      <!-- Content -->
      <div class="prose prose-invert prose-gold max-w-none
        prose-headings:text-content-primary prose-headings:font-bold
        prose-h1:text-hero prose-h1:font-light
        prose-h2:text-h2 prose-h2:mt-12 prose-h2:mb-4
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-content-primary prose-p:leading-relaxed
        prose-a:text-gold prose-a:underline hover:prose-a:text-gold-hover
        prose-strong:text-content-primary
        prose-ul:text-content-primary prose-ol:text-content-primary
        prose-li:marker:text-gold
        prose-blockquote:border-l-gold prose-blockquote:text-content-secondary
        prose-img:rounded-card">
        <Content />
      </div>

      <!-- Social share -->
      <div class="flex items-center gap-4 mt-12 pt-8 border-t border-border">
        <span class="text-sm text-content-muted">Share:</span>
        <a
          href={twitterShareUrl}
          target="_blank"
          rel="noopener"
          class="text-sm text-content-secondary hover:text-gold transition-colors"
        >
          Twitter / X
        </a>
        <a
          href={pinterestShareUrl}
          target="_blank"
          rel="noopener"
          class="text-sm text-content-secondary hover:text-gold transition-colors"
        >
          Pinterest
        </a>
        <button
          data-copy-url={postUrl}
          class="text-sm text-content-secondary hover:text-gold transition-colors cursor-pointer"
          onclick="navigator.clipboard.writeText(this.dataset.copyUrl);this.textContent='Copied!';setTimeout(()=>this.textContent='Copy link',2000)"
        >
          Copy link
        </button>
      </div>

      <!-- Bottom CTA -->
      <div class="mt-12 p-6 rounded-card bg-surface-elevated border border-border text-center">
        <p class="text-lg font-bold mb-2">Your closet, styled by AI.</p>
        <p class="text-content-secondary mb-4">See what you already own in a whole new way.</p>
        <a
          href={appStoreUrl}
          class="inline-flex items-center gap-2 bg-gold hover:bg-gold-hover text-surface-primary font-bold text-sm px-6 py-3 rounded-btn tracking-button transition-colors duration-200"
        >
          Download Dripmatiq Free
        </a>
      </div>

      <!-- Related posts -->
      {related.length > 0 && (
        <div class="mt-16">
          <h2 class="text-h2 font-bold mb-8">Keep reading</h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {related.map((r) => (
              <a href={`/blog/${r.slug}/`} class="group block">
                <div class="overflow-hidden rounded-card mb-3">
                  <img
                    src={(r.data.heroImage || `/blog/${r.slug}/hero.svg`).replace(/\.svg$/, '.jpg')}
                    alt={r.data.heroAlt || r.data.title}
                    width="600"
                    height="315"
                    loading="lazy"
                    decoding="async"
                    class="w-full aspect-[1200/630] object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                  />
                </div>
                <h3 class="font-bold group-hover:text-gold transition-colors">{r.data.title}</h3>
              </a>
            ))}
          </div>
        </div>
      )}
    </article>
  </main>
  <Footer />
</Base>
