---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { competitors } from '../../data/alternatives';

const appStore = 'https://apps.apple.com/app/dripmatiq/id6760679168';
const playStore = 'https://play.google.com/store/apps/details?id=com.dripmatic.app';

export function getStaticPaths() {
  return Object.keys(competitors).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const c = competitors[slug!];

const faqSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: c.faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
});
---

<Base title={c.title} description={c.description} jsonLd={faqSchema}>
  <Nav />
  <main>
    <!-- Hero -->
    <section class="pt-16 pb-12 sm:pt-32 sm:pb-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
        <p class="text-xs font-bold tracking-wide uppercase text-gold mb-3">
          <a href="/alternatives/" class="hover:text-gold-hover">Compare wardrobe apps</a> · {c.name}
        </p>
        <h1 class="text-3xl sm:text-hero font-light leading-tight mb-5">{c.h1}</h1>
        <p class="text-base sm:text-xl text-content-secondary max-w-2xl mx-auto mb-8">{c.intro}</p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href={appStore} class="inline-flex items-center justify-center bg-gold text-surface-primary font-bold text-base px-8 py-4 rounded-full shadow-lg hover:bg-gold-hover transition-colors duration-200 w-full sm:w-auto max-w-xs">
            Download Free — iOS
          </a>
          <a href={playStore} class="inline-flex items-center justify-center border border-border text-content-primary font-semibold text-sm px-8 py-3 rounded-full hover:border-border-active transition-colors duration-200 w-full sm:w-auto max-w-xs">
            Get it on Android
          </a>
        </div>
        <p class="text-xs text-content-muted mt-4">Free to download · No credit card required</p>
      </div>
    </section>

    <!-- Comparison table -->
    <section class="py-14 sm:py-20 bg-surface-secondary">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <h2 class="text-h2 font-light text-center mb-10">Dripmatiq vs {c.name}</h2>
        <div class="overflow-x-auto rounded-card border border-border">
          <table class="w-full text-sm text-left">
            <thead>
              <tr class="border-b border-border bg-surface-elevated">
                <th class="p-4 font-semibold text-content-secondary">Feature</th>
                <th class="p-4 font-bold text-gold">Dripmatiq</th>
                <th class="p-4 font-semibold">{c.name}</th>
              </tr>
            </thead>
            <tbody>
              {c.rows.map((r) => (
                <tr class="border-b border-border last:border-b-0">
                  <td class="p-4 text-content-secondary">{r.feature}</td>
                  <td class="p-4 text-gold font-semibold">{r.dripmatiq}</td>
                  <td class="p-4 text-content-secondary">{r.them}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        <p class="text-xs text-content-muted text-center mt-4">Comparison as of July 2026, based on public app listings. Verify current features on each store page.</p>
      </div>
    </section>

    <!-- Honest take -->
    <section class="py-14 sm:py-20">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 space-y-10">
        <div>
          <h2 class="text-h2 font-light mb-4">What {c.name} does well</h2>
          <p class="text-content-secondary leading-relaxed">{c.strengths}</p>
        </div>
        <div>
          <h2 class="text-h2 font-light mb-4">Where Dripmatiq goes further</h2>
          <p class="text-content-secondary leading-relaxed">{c.gap}</p>
        </div>
        <p class="text-sm text-content-muted">
          See the full field: <a href="/alternatives/" class="text-gold hover:text-gold-hover underline underline-offset-4">compare all wardrobe apps</a> ·
          <a href="/blog/dripmatiq-vs-whering-acloset-style-dna/" class="text-gold hover:text-gold-hover underline underline-offset-4">in-depth comparison</a>
        </p>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-14 sm:py-20 bg-surface-secondary">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <h2 class="text-h2 font-light text-center mb-12">Frequently asked questions</h2>
        <div class="space-y-6">
          {c.faqs.map((f) => (
            <div class="bg-surface-elevated border border-border rounded-card p-6">
              <h3 class="font-bold text-base mb-2">{f.q}</h3>
              <p class="text-content-secondary text-sm leading-relaxed">{f.a}</p>
            </div>
          ))}
        </div>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-12">
          <a href={appStore} class="inline-flex items-center justify-center bg-gold text-surface-primary font-bold text-base px-8 py-4 rounded-full shadow-lg hover:bg-gold-hover transition-colors duration-200 w-full sm:w-auto max-w-xs">
            Try Dripmatiq Free
          </a>
          <a href={playStore} class="inline-flex items-center justify-center border border-border text-content-primary font-semibold text-sm px-8 py-3 rounded-full hover:border-border-active transition-colors duration-200 w-full sm:w-auto max-w-xs">
            Get it on Android
          </a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Base>
