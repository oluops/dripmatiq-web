---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const siteUrl = 'https://dripmatiq.app';
const url = `${siteUrl}/terms/`;
const updated = '2026-05-09';
---

<Base
  title="Terms of Service — Dripmatiq"
  description="The terms that govern your use of the Dripmatiq website, blog, and iOS app. Plain-English summary up top."
  canonicalUrl={url}
>
  <Nav />
  <main class="pt-24 pb-16 px-4 sm:px-6">
    <article class="max-w-3xl mx-auto prose prose-invert prose-headings:font-light">
      <Breadcrumbs crumbs={[{ label: 'Home', href: '/' }, { label: 'Terms' }]} />
      <h1>Terms of Service</h1>
      <p class="text-content-muted text-sm">Last updated: {updated}</p>

      <h2>Plain-English summary</h2>
      <ul>
        <li>Use Dripmatiq for personal styling. Don't break it, don't abuse it.</li>
        <li>Your closet content stays yours. We get a limited license to process it so the app works.</li>
        <li>The service is provided "as is" — we're a small team, no warranty.</li>
      </ul>

      <h2>1. Acceptance</h2>
      <p>
        By using dripmatiq.app or the Dripmatiq iOS app ("Service"), you agree to these Terms. If you don't
        agree, don't use the Service.
      </p>

      <h2>2. Eligibility</h2>
      <p>You must be at least 13 years old (16 in the EEA/UK) to use Dripmatiq.</p>

      <h2>3. Your content</h2>
      <p>
        You retain ownership of photos and content you upload. You grant Dripmatiq a worldwide, non-exclusive,
        royalty-free license to host, process, and display that content solely to operate and improve the
        Service for you.
      </p>

      <h2>4. Acceptable use</h2>
      <p>You agree not to:</p>
      <ul>
        <li>Upload content that infringes others' rights or violates law.</li>
        <li>Reverse-engineer, scrape, or attempt to disrupt the Service.</li>
        <li>Use the Service to build a competing product.</li>
      </ul>

      <h2>5. Subscriptions and billing</h2>
      <p>
        Paid features are billed through the Apple App Store under Apple's standard subscription terms.
        Cancellations and refunds are handled by Apple.
      </p>

      <h2>6. Termination</h2>
      <p>
        You may delete your account at any time. We may suspend or terminate accounts that violate these Terms
        or harm the Service.
      </p>

      <h2>7. Disclaimer & liability</h2>
      <p>
        The Service is provided "AS IS" without warranties of any kind. To the fullest extent permitted by
        law, Dripmatiq's total liability is limited to the amount you paid us in the past 12 months (or USD 50,
        whichever is greater).
      </p>

      <h2>8. Changes</h2>
      <p>
        We may update these Terms; material changes will be announced in-app. Continued use after changes means
        you accept them.
      </p>

      <h2>9. Governing law</h2>
      <p>These Terms are governed by the laws of the State of California, USA.</p>

      <h2>10. Contact</h2>
      <p><!--email_off--><a href="mailto:legal@dripmatiq.app">legal@dripmatiq.app</a><!--/email_off--></p>
    </article>
  </main>
  <Footer />
</Base>
