---
import { getCollection } from 'astro:content';

// Surface the most recent posts on the homepage so new content is one click
// from the root page — helps Google discover and index posts faster.
const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<section class="py-16 sm:py-24">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-end justify-between mb-10">
      <div>
        <h2 class="text-h1 font-bold mb-2">From the blog</h2>
        <p class="text-content-secondary">Style intel, wardrobe math, and outfit strategy.</p>
      </div>
      <a href="/blog/" class="hidden sm:inline-block text-sm font-semibold text-gold hover:text-gold-hover transition-colors duration-200">
        All posts &rarr;
      </a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {posts.map((post) => {
        const href = `/blog/${post.slug}/`;
        const heroSrc = (post.data.heroImage || `/blog/${post.slug}/hero.svg`).replace(/\.svg$/, '.jpg');
        return (
          <article class="group">
            <a href={href} class="block">
              <div class="overflow-hidden rounded-card mb-4">
                <img
                  src={heroSrc}
                  alt={post.data.heroAlt || post.data.title}
                  width="1200"
                  height="630"
                  loading="lazy"
                  decoding="async"
                  class="w-full aspect-[1200/630] object-cover transition-transform duration-300 group-hover:scale-[1.02]"
                />
              </div>
              <h3 class="text-lg font-bold mb-1 group-hover:text-gold transition-colors duration-200">
                {post.data.title}
              </h3>
              <p class="text-sm text-content-secondary line-clamp-2">{post.data.description}</p>
            </a>
          </article>
        );
      })}
    </div>

    <div class="mt-8 text-center sm:hidden">
      <a href="/blog/" class="text-sm font-semibold text-gold hover:text-gold-hover transition-colors duration-200">
        All posts &rarr;
      </a>
    </div>
  </div>
</section>
