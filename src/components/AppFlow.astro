---
// AppFlow.astro — 9-step screenshot story: onboarding → outfit generation
const steps = [
  { src: '/screenshots/step1-onboarding.jpg', label: 'Create your profile', caption: 'Set your style archetype and preferences' },
  { src: '/screenshots/step2-closet.jpg', label: 'Build your closet', caption: 'Add pieces from your real wardrobe' },
  { src: '/screenshots/step3-add-garment.jpg', label: 'Catalog each item', caption: 'Category, color, fabric — AI handles the rest' },
  { src: '/screenshots/step5-style.jpg', label: 'Set style context', caption: 'Colors, body shape, skin tone for personalized picks' },
  { src: '/screenshots/fitmatic-outfit.jpg', label: 'AI generates your outfit', caption: 'Weather-aware, occasion-matched, fully reasoned' },
  { src: '/screenshots/fitmatic-tryon.jpg', label: 'See it on you', caption: 'FitMatic HD — try before you wear' },
  { src: '/screenshots/style-breakdown.jpg', label: 'Understand the "why"', caption: 'Color harmony, silhouette scoring, fit analysis' },
  { src: '/screenshots/outfit-tags.jpg', label: 'Tag & organize', caption: 'Occasion, mood, and style metadata on every look' },
  { src: '/screenshots/saved-looks.jpg', label: 'Save your favorites', caption: 'Build a library of go-to outfits' },
];
---

<section id="app-flow" class="py-20 bg-surface-primary overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-xs font-bold tracking-wide uppercase text-gold mb-3">See it in action</p>
      <h2 class="text-h2 font-light">From onboarding to outfit — in 9 steps</h2>
      <p class="text-content-secondary mt-3 max-w-lg mx-auto">Swipe through the real app experience.</p>
    </div>

    <!-- Step counter -->
    <div class="flex items-center justify-center gap-2 mb-8" id="flow-counter">
      <button class="text-content-muted hover:text-gold transition-colors p-2" id="flow-prev" aria-label="Previous">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <span class="text-sm text-content-secondary"><span id="flow-current">1</span> / 9</span>
      <button class="text-content-muted hover:text-gold transition-colors p-2" id="flow-next" aria-label="Next">
        <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>

    <!-- Carousel track -->
    <div class="relative">
      <div class="overflow-x-auto scrollbar-hide snap-x snap-mandatory scroll-smooth" id="flow-track">
        <div class="flex gap-6 px-[calc(50%-140px)] sm:px-[calc(50%-160px)]">
          {steps.map((step, i) => (
            <div class="flex-shrink-0 snap-center w-[280px] sm:w-[320px]" data-flow-slide={i}>
              <!-- Phone frame -->
              <div class="relative bg-surface-elevated border border-border rounded-[32px] overflow-hidden shadow-elevated p-2">
                <!-- Notch -->
                <div class="absolute top-3 left-1/2 -translate-x-1/2 w-14 h-1.5 bg-border rounded-full z-10"></div>
                <!-- Screenshot -->
                <img
                  src={step.src}
                  alt={step.label}
                  width="750"
                  height="1383"
                  loading={i < 3 ? 'eager' : 'lazy'}
                  decoding="async"
                  class="w-full rounded-[24px] object-cover"
                />
              </div>
              <!-- Caption -->
              <div class="mt-4 text-center px-2">
                <span class="inline-block text-[10px] font-bold uppercase tracking-widest text-gold mb-1">Step {i + 1}</span>
                <h3 class="text-sm font-bold text-content-primary">{step.label}</h3>
                <p class="text-xs text-content-secondary mt-1">{step.caption}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Dot indicators -->
    <div class="flex items-center justify-center gap-1.5 mt-8" id="flow-dots">
      {steps.map((_, i) => (
        <button
          class={`w-2 h-2 rounded-full transition-all duration-300 ${i === 0 ? 'bg-gold w-4' : 'bg-border'}`}
          data-dot={i}
          aria-label={`Go to step ${i + 1}`}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  (function () {
    const track = document.getElementById('flow-track');
    const dots = document.querySelectorAll('[data-dot]');
    const counter = document.getElementById('flow-current');
    const prevBtn = document.getElementById('flow-prev');
    const nextBtn = document.getElementById('flow-next');
    const slides = document.querySelectorAll('[data-flow-slide]');
    if (!track || !slides.length) return;

    let current = 0;

    function goTo(idx: number) {
      idx = Math.max(0, Math.min(slides.length - 1, idx));
      const slide = slides[idx] as HTMLElement;
      const trackEl = track as HTMLElement;
      const scrollLeft = slide.offsetLeft - trackEl.offsetWidth / 2 + slide.offsetWidth / 2;
      trackEl.scrollTo({ left: scrollLeft, behavior: 'smooth' });
      updateUI(idx);
    }

    function updateUI(idx: number) {
      current = idx;
      if (counter) counter.textContent = String(idx + 1);
      dots.forEach((d, i) => {
        (d as HTMLElement).classList.toggle('bg-gold', i === idx);
        (d as HTMLElement).classList.toggle('w-4', i === idx);
        (d as HTMLElement).classList.toggle('bg-border', i !== idx);
        (d as HTMLElement).classList.toggle('w-2', i !== idx);
      });
    }

    // Scroll-based detection
    let scrollTimeout: ReturnType<typeof setTimeout>;
    track.addEventListener('scroll', () => {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        const trackEl = track as HTMLElement;
        const center = trackEl.scrollLeft + trackEl.offsetWidth / 2;
        let closest = 0;
        let closestDist = Infinity;
        slides.forEach((s, i) => {
          const el = s as HTMLElement;
          const mid = el.offsetLeft + el.offsetWidth / 2;
          const dist = Math.abs(center - mid);
          if (dist < closestDist) { closestDist = dist; closest = i; }
        });
        updateUI(closest);
      }, 50);
    }, { passive: true });

    // Button handlers
    prevBtn?.addEventListener('click', () => goTo(current - 1));
    nextBtn?.addEventListener('click', () => goTo(current + 1));
    dots.forEach((d, i) => d.addEventListener('click', () => goTo(i)));

    updateUI(0);
  })();
</script>
