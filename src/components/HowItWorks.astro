---
const steps = [
  {
    num: '01',
    icon: '📷',
    title: 'Snap Your Closet',
    description: 'Take a photo of any garment. Dripmatiq identifies color, category, and style in seconds.',
    screenshot: '/screenshots/step3-add-garment.jpg',
    alt: 'Adding a garment to your digital closet',
  },
  {
    num: '02',
    icon: '👗',
    title: 'Outfits, Built for You',
    description: 'Dripmatiq mixes and matches your pieces into looks that suit your vibe and schedule.',
    screenshot: '/screenshots/fitmatic-tryon.jpg',
    alt: 'Outfit built with FitMatic virtual try-on',
  },
  {
    num: '03',
    icon: '✨',
    title: 'See It On You',
    description: 'FitMatic HD renders outfits on your body — see exactly how you’ll look before you dress.',
    screenshot: '/screenshots/fitmatic-outfit.jpg',
    alt: 'FitMatic HD virtual try-on showing styled outfit',
  },
];
---

<section id="how-it-works" class="py-20 sm:py-28 bg-surface-secondary">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <p class="text-xs font-bold tracking-wide uppercase text-gold text-center mb-3">How It Works</p>
    <h2 class="text-h2 font-light text-center mb-16">Three taps to your best look.</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
      {steps.map((step) => (
        <div class="flex flex-col items-center text-center group">
          <span class="text-xs font-bold tracking-wide text-content-muted mb-3">{step.num}</span>
          <div class="w-48 sm:w-56 rounded-phone overflow-hidden border border-border shadow-card mb-6 transition-transform duration-300 group-hover:scale-[1.02]">
            <img src={step.screenshot} alt={step.alt} class="w-full aspect-[9/19.5] object-cover" loading="lazy" />
          </div>
          <span class="text-3xl mb-3">{step.icon}</span>
          <h3 class="text-xl font-bold mb-2">{step.title}</h3>
          <p class="text-content-secondary text-sm max-w-xs">{step.description}</p>
        </div>
      ))}
    </div>

    <!-- Mid-page CTA -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-16 pt-16 border-t border-border">
      <a
        href="https://apps.apple.com/app/dripmatiq/id6760679168"
        class="inline-flex items-center justify-center gap-2 bg-gold text-surface-primary font-bold text-base px-8 py-4 rounded-full shadow-lg hover:bg-gold-hover transition-colors duration-200 w-full sm:w-auto max-w-xs"
      >
        Download Free — iOS
      </a>
      <a
        href="https://play.google.com/store/apps/details?id=com.dripmatic.app"
        class="inline-flex items-center justify-center gap-2 border border-border text-content-primary font-semibold text-sm px-8 py-3 rounded-full hover:border-border-active transition-colors duration-200 w-full sm:w-auto max-w-xs"
      >
        Get it on Android
      </a>
    </div>
    <p class="text-center text-xs text-content-muted mt-3">Free to download · No credit card required</p>
  </div>
</section>
