---
// Pricing / Pro section
---

<section class="py-20 sm:py-28 bg-surface-secondary">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <p class="text-xs font-bold tracking-wide uppercase text-gold text-center mb-3">Pricing</p>
    <h2 class="text-h2 font-light text-center mb-4">Start free. Upgrade when you're ready.</h2>
    <p class="text-content-secondary text-center max-w-lg mx-auto mb-12">
      Dripmatiq is free to download. Upgrade to Pro for more outfit suggestions and advanced styling filters, or go Elite for the highest AI quota and the full style parameter suite.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-4xl mx-auto">
      <!-- Free -->
      <div class="bg-surface-elevated border border-border rounded-card p-8">
        <h3 class="font-bold text-lg mb-1">Free</h3>
        <p class="text-content-muted text-sm mb-6">Get started</p>
        <p class="text-3xl font-light mb-6">$0</p>
        <ul class="space-y-3 text-sm text-content-secondary">
          <li class="flex items-start gap-2"><span class="text-gold">✓</span> Closet scanner</li>
          <li class="flex items-start gap-2"><span class="text-gold">✓</span> 25 outfit suggestions/month</li>
          <li class="flex items-start gap-2"><span class="text-gold">✓</span> Up to 20 garments</li>
          <li class="flex items-start gap-2"><span class="text-gold">✓</span> 3 FitMatic try-ons/month</li>
        </ul>
      </div>

      <!-- Pro -->
      <div class="bg-surface-elevated border-2 border-gold rounded-card p-8 relative">
        <span class="absolute -top-3 left-1/2 -translate-x-1/2 bg-gold text-surface-primary text-xs font-bold px-3 py-1 rounded-full tracking-button">POPULAR</span>
        <h3 class="font-bold text-lg mb-1">Pro</h3>
        <p class="text-content-muted text-sm mb-6">Your full wardrobe, styled</p>
        <p class="text-3xl font-light mb-1">$6.99<span class="text-base text-content-muted">/mo</span></p>
        <p class="text-xs text-content-muted mb-6">or $59.99/year</p>
        <ul class="space-y-3 text-sm text-content-secondary">
          <li class="flex items-start gap-2"><span class="text-gold">✓</span> Unlimited garments</li>
          <li class="flex items-start gap-2"><span class="text-gold">✓</span> 400 outfit suggestions/month</li>
          <li class="flex items-start gap-2"><span class="text-gold">✓</span> Occasion, formality & color filters</li>
          <li class="flex items-start gap-2"><span class="text-gold">✓</span> 10 FitMatic try-ons/month</li>
        </ul>
      </div>

      <!-- Elite -->
      <div class="bg-surface-elevated border border-border rounded-card p-8">
        <h3 class="font-bold text-lg mb-1">Elite</h3>
        <p class="text-content-muted text-sm mb-6">Personal stylist AI</p>
        <p class="text-3xl font-light mb-1">$15.99<span class="text-base text-content-muted">/mo</span></p>
        <p class="text-xs text-content-muted mb-6">or $169.99/year</p>
        <ul class="space-y-3 text-sm text-content-secondary">
          <li class="flex items-start gap-2"><span class="text-gold">✓</span> Everything in Pro</li>
          <li class="flex items-start gap-2"><span class="text-gold">✓</span> 1,200 outfit suggestions/month</li>
          <li class="flex items-start gap-2"><span class="text-gold">✓</span> Skin tone, trend, brand & mood filters</li>
          <li class="flex items-start gap-2"><span class="text-gold">✓</span> 20 FitMatic try-ons/month</li>
        </ul>
      </div>
    </div>

    <div class="text-center mt-10">
      <a
        href="https://apps.apple.com/app/dripmatiq/id6760679168"
        class="inline-flex items-center gap-2 bg-gold hover:bg-gold-hover text-surface-primary font-extrabold px-8 py-4 rounded-btn tracking-button transition-colors duration-200"
      >
        Download Dripmatiq
      </a>
    </div>
  </div>
</section>
