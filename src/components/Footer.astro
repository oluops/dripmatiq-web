---
const year = new Date().getFullYear();
const links = [
  { label: 'About', href: '/about/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'Press', href: '/press/' },
  { label: 'Privacy Policy', href: '/privacy-policy.html' },
  { label: 'Terms of Service', href: '/terms-of-service.html' },
  { label: 'Support', href: '/support.html' },
  { label: 'How to Use', href: '/how-to.html' },
];
---

<footer class="py-12 border-t border-border">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6 mb-8">
      <a href="/" class="flex items-center gap-2">
        <img src="/assets/icon.png" alt="Dripmatiq" class="w-8 h-8 rounded-lg" />
        <span class="text-lg font-bold tracking-wide">Dripmatiq</span>
      </a>
      <a
        href="https://apps.apple.com/app/dripmatiq/id6760679168"
        class="inline-flex items-center gap-2 bg-gold hover:bg-gold-hover text-surface-primary font-bold text-sm px-5 py-2.5 rounded-btn tracking-button transition-colors duration-200"
      >
        Download Dripmatiq
      </a>
    </div>
    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 mb-6">
      {links.map((link) => (
        <a href={link.href} class="text-sm text-content-secondary hover:text-content-primary transition-colors">
          {link.label}
        </a>
      ))}
    </div>
    <p class="text-center text-xs text-content-muted">
      © {year} Dripmatiq. All rights reserved.
    </p>
  </div>
</footer>
