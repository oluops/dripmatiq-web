---
const features = [
  { icon: '🪄', title: 'AI Outfit Suggestions', description: 'An AI stylist that learns your taste and generates outfit ideas from your own clothes.' },
  { icon: '👗', title: 'Virtual Try-On', description: 'See outfits on your body — not a flat collage — before you get dressed or buy anything new.' },
  { icon: '📅', title: 'Outfit Calendar', description: 'Fresh looks every morning, planned around your calendar and the weather.' },
  { icon: '📸', title: 'Digital Closet Organizer', description: 'Digitize your wardrobe in minutes — photograph garments and auto-tag color, category, and season.' },
  { icon: '🎨', title: 'Color Analysis', description: 'Colors paired to your palette and skin tone, so every combination actually works.' },
  { icon: '🔒', title: 'Privacy First', description: 'Your wardrobe data stays on-device. No selling, no sharing.' },
];
---

<section class="py-20 sm:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <p class="text-xs font-bold tracking-wide uppercase text-gold text-center mb-3">Features</p>
    <h2 class="text-h2 font-light text-center mb-4">Your digital wardrobe, working for you.</h2>
    <p class="text-content-secondary text-center max-w-xl mx-auto mb-16">
      Most virtual closet apps stop at cataloging. Dripmatiq is the one that styles you — and shows you the result on your body.
    </p>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-6 lg:gap-8">
      {features.map((f) => (
        <div class="bg-surface-secondary border border-border rounded-card p-6 hover:border-border-active transition-colors duration-200">
          <span class="text-3xl mb-4 block">{f.icon}</span>
          <h3 class="font-bold text-base mb-2">{f.title}</h3>
          <p class="text-content-secondary text-sm leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mt-14">
      <a
        href="https://apps.apple.com/app/dripmatiq/id6760679168"
        class="inline-flex items-center justify-center gap-2 bg-gold text-surface-primary font-bold text-base px-8 py-4 rounded-full shadow-lg hover:bg-gold-hover transition-colors duration-200 w-full sm:w-auto max-w-xs"
      >
        Download Free — iOS
      </a>
      <a
        href="https://play.google.com/store/apps/details?id=com.dripmatic.app"
        class="inline-flex items-center justify-center gap-2 border border-border text-content-primary font-semibold text-sm px-8 py-3 rounded-full hover:border-border-active transition-colors duration-200 w-full sm:w-auto max-w-xs"
      >
        Get it on Android
      </a>
    </div>
    <p class="text-center text-sm text-content-muted mt-6">
      Switching from another wardrobe app? See how Dripmatiq compares as a
      <a href="/alternatives/" class="text-gold hover:text-gold-hover underline underline-offset-4">Whering, Acloset &amp; Stylebook alternative</a>.
    </p>
  </div>
</section>
