---
// Hero — headline, subhead, CTA, store badges, phone mockup
import Waitlist from './Waitlist.astro';
---

<section class="relative pt-20 pb-12 sm:pt-36 sm:pb-28 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col lg:flex-row items-center gap-8 sm:gap-12 lg:gap-16">
      <!-- Text -->
      <div class="flex-1 text-center lg:text-left">
        <h1 class="text-3xl sm:text-hero font-light leading-tight mb-3 sm:mb-4">
          Your closet, <span class="text-gold">styled by AI.</span>
        </h1>
        <p class="text-base sm:text-xl text-content-secondary max-w-lg mx-auto lg:mx-0 mb-6 sm:mb-8">
          Dripmatiq scans your wardrobe, learns your taste, and builds daily outfits you'll actually wear.
        </p>
        <!-- Store badges -->
        <div class="flex items-center gap-3 sm:gap-4 justify-center lg:justify-start">
          <a href="https://apps.apple.com/app/dripmatiq/id6760679168" class="transition-opacity hover:opacity-80">
            <img src="/assets/badge-appstore.svg" alt="Download on the App Store" class="h-[36px] sm:h-[40px]" />
          </a>
          <a href="https://play.google.com/store/apps/details?id=com.dripmatic.app" class="transition-opacity hover:opacity-80">
            <img src="/assets/badge-googleplay.svg" alt="Get it on Google Play" class="h-[36px] sm:h-[40px]" />
          </a>
        </div>

        <div class="mt-4 flex justify-center lg:justify-start">
          <a href="https://www.shipit.buzz/products/dripmatiq?ref=badge" target="_blank" rel="noopener noreferrer" class="transition-opacity hover:opacity-90">
            <img src="https://www.shipit.buzz/api/products/dripmatiq/badge?theme=dark" alt="Featured on Shipit" class="h-[40px]" />
          </a>
        </div>

        <Waitlist />
        <p class="mt-3 sm:mt-4 text-sm text-content-muted">See how it works ↓</p>
      </div>

      <!-- Phone mockup -->
      <div class="flex-1 flex justify-center">
        <div class="relative w-[220px] sm:w-[300px] lg:w-[340px]">
          <div class="rounded-phone bg-surface-elevated border-2 border-border-active shadow-elevated overflow-hidden aspect-[9/19.5]">
            <!-- Looping 4x montage video -->
            <video
              autoplay
              muted
              loop
              playsinline
              poster="/screenshots/fitmatic-outfit.jpg"
              class="w-full h-full object-cover"
            >
              <source src="/app-previews/preview3-montage-4x.mp4" type="video/mp4" />
              <!-- Fallback for reduced motion / no video support -->
              <img
                src="/screenshots/fitmatic-outfit.jpg"
                alt="Dripmatiq AI-generated outfit with FitMatic virtual try-on"
                class="w-full h-full object-cover"
              />
            </video>
          </div>
          <!-- Decorative glow -->
          <div class="absolute -inset-4 bg-gold/5 rounded-full blur-3xl -z-10"></div>
        </div>
      </div>
    </div>
  </div>
</section>
