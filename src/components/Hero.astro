---
// Hero — headline, subhead, CTA, store badges, phone mockup
import Waitlist from './Waitlist.astro';
---

<section class="relative pt-28 pb-20 sm:pt-36 sm:pb-28 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex flex-col-reverse lg:flex-row items-center gap-12 lg:gap-16">
      <!-- Text -->
      <div class="flex-1 text-center lg:text-left">
        <h1 class="text-hero font-light leading-tight mb-4">
          Your closet, <span class="text-gold">styled by AI.</span>
        </h1>
        <p class="text-lg sm:text-xl text-content-secondary max-w-lg mx-auto lg:mx-0 mb-8">
          Dripmatiq scans your wardrobe, learns your taste, and builds daily outfits you'll actually wear.
        </p>
        <!-- Store badges -->
        <div class="flex items-center gap-4 justify-center lg:justify-start">
          <a href="https://apps.apple.com/app/dripmatiq/id6760679168" class="transition-opacity hover:opacity-80">
            <img src="/assets/badge-appstore.svg" alt="Download on the App Store" class="h-[40px]" />
          </a>
          <a href="https://play.google.com/store/apps/details?id=com.dripmatic.app" class="transition-opacity hover:opacity-80">
            <img src="/assets/badge-googleplay.svg" alt="Get it on Google Play" class="h-[40px]" />
          </a>
        </div>
        <Waitlist />
        <p class="mt-4 text-sm text-content-muted">See how it works ↓</p>
      </div>

      <!-- Phone mockup -->
      <div class="flex-1 flex justify-center">
        <div class="relative w-[260px] sm:w-[300px] lg:w-[340px]">
          <div class="rounded-phone bg-surface-elevated border-2 border-border-active shadow-elevated overflow-hidden aspect-[9/19.5]">
            <!-- Static fallback for v1 (reduced motion friendly) -->
            <img
              src="/screenshots/fitmatic-outfit.jpg"
              alt="Dripmatiq AI-generated outfit with FitMatic virtual try-on"
              class="w-full h-full object-cover"
              loading="eager"
            />
          </div>
          <!-- Decorative glow -->
          <div class="absolute -inset-4 bg-gold/5 rounded-full blur-3xl -z-10"></div>
        </div>
      </div>
    </div>
  </div>
</section>
